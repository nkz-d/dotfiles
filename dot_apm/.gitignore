
# APM per-machine build output — regenerated by `apm install -g`. Only apm.yml
# is committed; the pinned commit in it is the reproducibility anchor. The lock
# is machine-specific (deployed_files depend on installed assistants).
apm.lock.yaml
apm_modules/

# Project-scope skill deploys that `apm install` (without -g) drops here.
# This is the GLOBAL apm project: skills are deployed to user scope (~/.claude,
# ~/.agents, ...) by run_onchange_after_apm-install, never into ~/.apm itself.
# chezmoi already ignores these dot-prefixed dirs; keep them out of git too.
.claude/
.agents/
.codex/
