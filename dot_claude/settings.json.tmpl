{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "extendedThinking": {
    "enabled": true,
    "showThinkingProcess": true
  },
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "mv-claude-code-history@nekoze-skills": true
  },
  "env": {
    "DISABLE_ZOXIDE": "1",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "extraKnownMarketplaces": {
    "nekoze-skills": {
      "source": {
        "source": "github",
        "repo": "nkz-d/skills"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '{{ .chezmoi.homeDir }}/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "includeCoAuthoredBy": true,
  "language": "日本語",
  "permissions": {
    "defaultMode": "{{ .claude_default_mode | default "acceptEdits" }}"
  },
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "tui": "default",
  "statusLine": {
    "type": "command",
    "command": "'{{ .chezmoi.homeDir }}/.claude/scripts/runcat-statusline.py'"
  }
}
