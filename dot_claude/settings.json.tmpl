{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "mv-claude-code-history@nekoze-skills": true
  },
  "env": {
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "DISABLE_ZOXIDE": "1"
  },
  "extendedThinking": {
    "enabled": true,
    "showThinkingProcess": true
  },
  "extraKnownMarketplaces": {
    "nekoze-skills": {
      "source": {
        "repo": "nkz-d/skills",
        "source": "github"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '{{ .chezmoi.homeDir }}/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "includeCoAuthoredBy": true,
  "language": "日本語",
  "permissions": {
    "defaultMode": "{{ .claude_default_mode | default "acceptEdits" }}"
  },
  "remoteControlAtStartup": false,
  "showThinkingSummaries": true,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "in=$(cat); printf '%s' \"$in\" | '{{ .chezmoi.homeDir }}/.claude/scripts/runcat-statusline.py' >/dev/null 2>&1; printf '%s' \"$in\" | '{{ .chezmoi.homeDir }}/.claude/scripts/statusline.py'",
    "type": "command"
  },
  "tui": "default"
}